{
    "name": "takshak/adash",
    "keywords": ["laravel", "breeze", "admin panel", "panel", "dashboard"],
    "description": "Simple admin panel starter kit",
    "license": "MIT",
    "authors": [
        {
            "name": "Takshak Tiwari",
            "email": "takshaktiwari@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/breeze": "^2.3",
        "takshak/alertt": "^1.0",
        "takshak/imager": "^1.0",
        "maatwebsite/excel": "^3.1",
        "yajra/laravel-datatables": "*",
        "laravel/prompts": "^0.3.0"
    },
    "autoload": {
        "psr-4" : {
            "Takshak\\Adash\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Takshak\\Adash\\Providers\\AdashServiceProvider"
            ]
        }
    }
}
